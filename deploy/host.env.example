# Copy outside the repository, for example to /etc/shioaji-lob-recorder/host.env.
LOB_DATA_ROOT=/mnt/lob-data
LOB_CREDENTIAL_FILE=/etc/shioaji-lob-recorder/shioaji.env
LOB_MODE=live
LOB_WARN_PERCENT=80
LOB_STOP_PERCENT=90
LOB_BATCH_SIZE=1000
LOB_FLUSH_MS=250
LOB_QUEUE_SIZE=20000
LOB_SHIOAJI_LOG_MAX_BYTES=20000000
