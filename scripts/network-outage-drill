#!/bin/sh
set -eu

test "$(id -u)" -eq 0 || { echo "run with sudo" >&2; exit 1; }
test "$#" -eq 4 \
  || { echo "usage: sudo scripts/network-outage-drill ABSOLUTE_DATA_ROOT HOST_ENV_FILE SECONDS --confirm-network-outage" >&2; exit 2; }

data_root="$1"
host_env="$2"
duration="$3"
confirmation="$4"
test "$confirmation" = "--confirm-network-outage" \
  || { echo "explicit network outage confirmation is required" >&2; exit 1; }
case "$duration" in
  ''|*[!0-9]*) echo "network outage duration must be an integer" >&2; exit 1 ;;
esac
test "$duration" -ge 30 && test "$duration" -le 300 \
  || { echo "network outage duration must be between 30 and 300 seconds" >&2; exit 1; }
test "${data_root#/}" != "$data_root" && test "$data_root" != "/" \
  || { echo "unsafe data root" >&2; exit 1; }
test -f "$host_env" || { echo "host config is unavailable" >&2; exit 1; }
configured_root="$(sed -n 's/^LOB_DATA_ROOT=//p' "$host_env")"
test "$configured_root" = "$data_root" \
  || { echo "data root does not match host config" >&2; exit 1; }
test "$(sed -n 's/^LOB_MODE=//p' "$host_env")" = "live" \
  || { echo "network outage drill requires LOB_MODE=live" >&2; exit 1; }

dc() {
  docker compose --env-file "$host_env" "$@"
}

service_running() {
  dc ps --status running --services | awk -v service="$1" '$0 == service { found = 1 } END { exit(found ? 0 : 1) }'
}

scripts/storage-check "$data_root"
docker compose --env-file "$host_env" config --quiet
service_running collector || { echo "collector must be running" >&2; exit 1; }
service_running clickhouse || { echo "clickhouse must be running" >&2; exit 1; }

collector_id="$(dc ps -q collector)"
test -n "$collector_id" && test "$(printf '%s\n' "$collector_id" | wc -l | tr -d ' ')" -eq 1 \
  || { echo "exactly one collector container is required" >&2; exit 1; }
compose_project="$(docker inspect --format '{{ index .Config.Labels "com.docker.compose.project" }}' "$collector_id")"
test -n "$compose_project" || { echo "collector compose project label is unavailable" >&2; exit 1; }
outbound_network="$(docker network ls \
  --filter "label=com.docker.compose.project=$compose_project" \
  --filter "label=com.docker.compose.network=outbound" -q)"
test -n "$outbound_network" && test "$(printf '%s\n' "$outbound_network" | wc -l | tr -d ' ')" -eq 1 \
  || { echo "exactly one collector outbound network is required" >&2; exit 1; }

before="/var/lib/lob/parquet/network-outage-before.json"
after="/var/lib/lob/parquet/network-outage-after.json"
evidence="/var/lib/lob/parquet/network-outage-report.json"
dc exec -T collector lob-recorder acceptance-report \
  --host clickhouse --health-file /var/lib/lob/private-runtime/collector/health.json \
  --output "$before"

restore_network() {
  docker network connect "$outbound_network" "$collector_id" >/dev/null 2>&1 || true
}
trap restore_network EXIT HUP INT TERM

echo "starting confirmed collector outbound network outage drill"
docker network disconnect "$outbound_network" "$collector_id"
sleep "$duration"
docker network connect "$outbound_network" "$collector_id"

attempt=0
while :; do
  if dc exec -T collector lob-recorder acceptance-report \
      --host clickhouse --health-file /var/lib/lob/private-runtime/collector/health.json \
      --output "$after" >/dev/null 2>&1; then
    if dc exec -T collector lob-recorder network-outage-verify \
        --before "$before" --after "$after" --outage-seconds "$duration" \
        --output "$evidence" >/dev/null 2>&1; then
      break
    fi
  fi
  attempt=$((attempt + 1))
  test "$attempt" -lt 60 || { echo "network reconnect was not verified within 300 seconds" >&2; exit 1; }
  sleep 5
done

trap - EXIT HUP INT TERM
echo "network outage drill complete; privacy-safe report written to the data-root parquet area"
