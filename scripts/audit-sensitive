#!/bin/sh
set -eu

status=0
tracked="$(git ls-files --cached --others --exclude-standard | sed '/^scripts\/audit-sensitive$/d')"
for pattern in \
  '-----BEGIN (RSA |EC |OPENSSH )?PRIVATE KEY-----' \
  'Bearer[[:space:]]+[A-Za-z0-9._~+/-]{16,}' \
  '[A-Z][12][0-9]{8}' \
  '/Users/[^/[:space:]]+' \
  '/home/[^/[:space:]]+'; do
  matches="$(printf '%s\n' "$tracked" | xargs rg -l --no-messages -e "$pattern" || true)"
  if test -n "$matches"; then
    printf 'sensitive-pattern candidate files:\n%s\n' "$matches"
    status=1
  fi
done
exit "$status"
